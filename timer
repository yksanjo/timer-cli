#!/usr/bin/env python3
"""timer: Simple countdown timer."""

import sys
import time
import subprocess
import re


def parse_time(s):
    """Parse time string like 5m, 1h30m, 90s, 25."""
    s = s.lower().strip()

    # Just a number = minutes
    if s.isdigit():
        return int(s) * 60

    total = 0

    # Hours
    h = re.search(r"(\d+)h", s)
    if h:
        total += int(h.group(1)) * 3600

    # Minutes
    m = re.search(r"(\d+)m", s)
    if m:
        total += int(m.group(1)) * 60

    # Seconds
    sec = re.search(r"(\d+)s", s)
    if sec:
        total += int(sec.group(1))

    return total if total > 0 else None


def format_time(seconds):
    """Format seconds as MM:SS or HH:MM:SS."""
    h = seconds // 3600
    m = (seconds % 3600) // 60
    s = seconds % 60

    if h > 0:
        return f"{h}:{m:02d}:{s:02d}"
    return f"{m}:{s:02d}"


def notify(message):
    """Send macOS notification."""
    subprocess.run([
        "osascript", "-e",
        f'display notification "{message}" with title "Timer"'
    ])
    # Also play sound
    subprocess.run(["afplay", "/System/Library/Sounds/Glass.aiff"])


def main():
    if len(sys.argv) < 2:
        print("Usage: timer <duration>")
        print("  timer 5       (5 minutes)")
        print("  timer 5m      (5 minutes)")
        print("  timer 1h30m   (1 hour 30 min)")
        print("  timer 90s     (90 seconds)")
        return

    seconds = parse_time(sys.argv[1])

    if not seconds:
        print(f"Invalid time: {sys.argv[1]}")
        return

    label = " ".join(sys.argv[2:]) if len(sys.argv) > 2 else "Timer"
    print(f"⏱ {label}: {format_time(seconds)}")

    try:
        while seconds > 0:
            print(f"\r⏱ {format_time(seconds)} ", end="", flush=True)
            time.sleep(1)
            seconds -= 1

        print(f"\r⏱ Done!          ")
        notify(f"{label} finished!")

    except KeyboardInterrupt:
        print(f"\n⏱ Cancelled")


if __name__ == "__main__":
    main()
